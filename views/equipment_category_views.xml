<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ─── Form ─────────────────────────────────────────────────── -->
    <record id="view_radio_category_form" model="ir.ui.view">
        <field name="name">chc_radio_listing.category.form</field>
        <field name="model">chc_radio_listing.category</field>
        <field name="arch" type="xml">
            <form string="Catégorie / Listing">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_equipments"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-wrench">
                            <field name="equipment_count" widget="statinfo" string="Équipements"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="color" widget="color_picker"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ─── List ─────────────────────────────────────────────────── -->
    <record id="view_radio_category_list" model="ir.ui.view">
        <field name="name">chc_radio_listing.category.list</field>
        <field name="model">chc_radio_listing.category</field>
        <field name="arch" type="xml">
            <tree string="Listings" editable="top">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="equipment_count" string="Équipements"/>
                <field name="active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <!-- ─── Action ───────────────────────────────────────────────── -->
    <record id="action_radio_category" model="ir.actions.act_window">
        <field name="name">Listings / Catégories</field>
        <field name="res_model">chc_radio_listing.category</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
