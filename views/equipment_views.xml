<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ═══════════════════════════════════════════════════════
         LIST VIEW — avec décorations de statut et alertes
    ══════════════════════════════════════════════════════════ -->
    <record id="view_radio_equipment_list" model="ir.ui.view">
        <field name="name">chc_radio_listing.equipment.list</field>
        <field name="model">chc_radio_listing.equipment</field>
        <field name="arch" type="xml">
            <tree string="Équipements"
                  decoration-danger="statut == 'en_panne'"
                  decoration-warning="statut == 'en_maintenance'"
                  decoration-muted="statut == 'hors_service'">
                <field name="statut" column_invisible="True"/>
                <field name="modalite" string="Équipements" optional="show"/>
                <field name="site"/>
                <field name="equip_type" string="Type"/>
                <field name="aet" optional="hide"/>
                <field name="ip" optional="hide"/>
                <field name="mac" optional="hide"/>
                <field name="marque" optional="show"/>
                <field name="modele" optional="hide"/>
                <field name="numero_serie" optional="hide"/>
                <field name="numero_inventaire" string="N° CHC" optional="show"/>
                <field name="service" optional="show"/>
                <field name="salle" optional="show"/>
                <field name="reseau" optional="hide"/>
                <field name="os" optional="hide"/>
                <field name="responsable" string="Référent" optional="hide"/>
                <field name="write_date" string="Dernière modif" optional="show"/>
            </tree>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════
         FORM VIEW
    ══════════════════════════════════════════════════════════ -->
    <record id="view_radio_equipment_form" model="ir.ui.view">
        <field name="name">chc_radio_listing.equipment.form</field>
        <field name="model">chc_radio_listing.equipment</field>
        <field name="arch" type="xml">
            <form string="Équipement">
                <header>
                    <button name="action_marquer_en_service"
                            string="En service"
                            type="object"
                            class="btn-success"
                            invisible="statut == 'en_service'"/>
                    <button name="action_marquer_en_panne"
                            string="Signaler panne"
                            type="object"
                            class="btn-danger"
                            invisible="statut == 'en_panne'"/>
                    <button name="action_marquer_en_maintenance"
                            string="En maintenance"
                            type="object"
                            class="btn-warning"
                            invisible="statut == 'en_maintenance'"/>
                    <button name="action_marquer_hors_service"
                            string="Hors service"
                            type="object"
                            class="btn-secondary"
                            invisible="statut == 'hors_service'"/>
                    <field name="statut" widget="statusbar"
                           statusbar_visible="en_service,en_maintenance,en_panne,hors_service"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="site"/>
                            <span invisible="not equip_type"> / </span>
                            <field name="equip_type" placeholder="Type"/>
                        </h1>
                        <h3>
                            <field name="marque" placeholder="Marque"/>
                            <span invisible="not modele"> — </span>
                            <field name="modele" placeholder="Modèle"/>
                        </h3>
                    </div>

                    <group>
                        <group string="Identification">
                            <field name="modalite" string="Équipements"/>
                            <field name="category_id" invisible="1"/>
                            <field name="service"/>
                            <field name="salle"/>
                            <field name="responsable" string="Référent"/>
                        </group>
                        <group string="Numéros">
                            <field name="numero_serie"/>
                            <field name="numero_inventaire"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>

                    <group string="Réseau / DICOM">
                        <group>
                            <field name="aet"/>
                            <field name="assoc_dicom"/>
                        </group>
                        <group>
                            <field name="ip"/>
                            <field name="mac"/>
                            <field name="reseau"/>
                            <field name="os"/>
                        </group>
                    </group>

                    <field name="designation" invisible="1"/>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════
         KANBAN VIEW
    ══════════════════════════════════════════════════════════ -->
    <record id="view_radio_equipment_kanban" model="ir.ui.view">
        <field name="name">chc_radio_listing.equipment.kanban</field>
        <field name="model">chc_radio_listing.equipment</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_small_column"
                    default_group_by="modalite"
                    quick_create="false">
                <field name="statut"/>
                <field name="color"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_card oe_kanban_global_click
                            #{record.statut.raw_value == 'en_panne' ? 'border-danger' : ''}
                            #{record.statut.raw_value == 'en_maintenance' ? 'border-warning' : ''}">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <field name="designation"/>
                                        </strong>
                                        <small class="o_kanban_record_subtitle text-muted">
                                            <field name="marque"/>
                                            <t t-if="record.modele.value"> — <field name="modele"/></t>
                                        </small>
                                    </div>
                                    <!-- Badge statut -->
                                    <div>
                                        <span t-attf-class="badge
                                            #{record.statut.raw_value == 'en_service' ? 'bg-success' : ''}
                                            #{record.statut.raw_value == 'en_panne' ? 'bg-danger' : ''}
                                            #{record.statut.raw_value == 'en_maintenance' ? 'bg-warning text-dark' : ''}
                                            #{record.statut.raw_value == 'hors_service' ? 'bg-secondary' : ''}
                                            #{record.statut.raw_value == 'en_attente' ? 'bg-info' : ''}
                                            text-white rounded-pill px-2 py-1" style="font-size:10px;">
                                            <field name="statut"/>
                                        </span>
                                    </div>
                                </div>
                                <div class="o_kanban_record_body mt-1">
                                    <div t-if="record.salle.value" class="text-muted" style="font-size:12px;">
                                        <i class="fa fa-map-marker me-1"/>
                                        <field name="salle"/>
                                    </div>
                                    <div t-if="record.numero_inventaire.value" class="text-muted" style="font-size:11px;">
                                        <i class="fa fa-tag me-1"/>
                                        <field name="numero_inventaire"/>
                                    </div>
                                </div>
                                <div class="o_kanban_record_bottom mt-2">
                                    <div class="oe_kanban_bottom_right">
                                        <field name="activity_ids" widget="kanban_activity"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════
         SEARCH VIEW — filtres et regroupements
    ══════════════════════════════════════════════════════════ -->
    <record id="view_radio_equipment_search" model="ir.ui.view">
        <field name="name">chc_radio_listing.equipment.search</field>
        <field name="model">chc_radio_listing.equipment</field>
        <field name="arch" type="xml">
            <search string="Rechercher un équipement">
                <!-- Recherche libre -->
                <field name="designation" string="Désignation"/>
                <field name="marque"/>
                <field name="modele"/>
                <field name="numero_serie" string="N° de série"/>
                <field name="numero_inventaire" string="N° d'inventaire"/>
                <field name="salle"/>
                <field name="responsable" string="Référent"/>
                <field name="modalite" string="Équipements"/>

                <!-- Filtres prédéfinis -->
                <separator/>
                <filter name="en_service"    string="En service"     domain="[('statut','=','en_service')]"/>
                <filter name="en_panne"      string="En panne"       domain="[('statut','=','en_panne')]"/>
                <filter name="en_maintenance" string="En maintenance" domain="[('statut','=','en_maintenance')]"/>
                <filter name="hors_service"  string="Hors service"   domain="[('statut','=','hors_service')]"/>
                <separator/>
                <filter name="inactive" string="Archivés" domain="[('active','=',False)]"/>

                <!-- Regroupements -->
                <group expand="0" string="Regrouper par">
                    <filter name="group_materiel" string="Équipements"
                            context="{'group_by': 'modalite'}"/>
                    <filter name="group_statut"   string="Statut"
                            context="{'group_by': 'statut'}"/>
                    <filter name="group_salle"    string="Salle"
                            context="{'group_by': 'salle'}"/>
                    <filter name="group_marque"   string="Marque"
                            context="{'group_by': 'marque'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════
         PIVOT VIEW — statistiques
    ══════════════════════════════════════════════════════════ -->
    <record id="view_radio_equipment_pivot" model="ir.ui.view">
        <field name="name">chc_radio_listing.equipment.pivot</field>
        <field name="model">chc_radio_listing.equipment</field>
        <field name="arch" type="xml">
            <pivot string="Statistiques équipements" disable_linking="false">
                <field name="modalite" string="Équipements" type="row"/>
                <field name="statut"      type="col"/>
                <field name="designation" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════
         GRAPH VIEW
    ══════════════════════════════════════════════════════════ -->
    <record id="view_radio_equipment_graph" model="ir.ui.view">
        <field name="name">chc_radio_listing.equipment.graph</field>
        <field name="model">chc_radio_listing.equipment</field>
        <field name="arch" type="xml">
            <graph string="Répartition équipements" type="bar">
                <field name="modalite" string="Équipements" type="row"/>
                <field name="statut"      type="col"/>
            </graph>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════
         ACTIONS
    ══════════════════════════════════════════════════════════ -->
    <record id="action_equipment_all" model="ir.actions.act_window">
        <field name="name">Tous les équipements</field>
        <field name="res_model">chc_radio_listing.equipment</field>
        <field name="view_mode">list,kanban,form,pivot,graph</field>
        <field name="search_view_id" ref="view_radio_equipment_search"/>
        <field name="context">{}</field>
    </record>

    <record id="action_equipment_en_panne" model="ir.actions.act_window">
        <field name="name">Équipements en panne</field>
        <field name="res_model">chc_radio_listing.equipment</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('statut', '=', 'en_panne')]</field>
    </record>
</odoo>
