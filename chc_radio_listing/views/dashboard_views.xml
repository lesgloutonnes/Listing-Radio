<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Dashboard — utilise les vues graph/pivot existantes
        pour un affichage côte-à-côte sur la page d'accueil.
    -->
    <record id="action_radio_dashboard" model="ir.actions.act_window">
        <field name="name">Tableau de bord</field>
        <field name="res_model">chc_radio_listing.equipment</field>
        <field name="view_mode">graph,pivot,list</field>
        <field name="search_view_id" ref="chc_radio_listing.view_radio_equipment_search"/>
        <field name="context">{
            'search_default_group_materiel': 1,
        }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Aucun équipement encore enregistré.
            </p>
            <p>
                Commencez par ajouter des équipements ou importez votre fichier Excel existant.
            </p>
        </field>
    </record>
</odoo>
